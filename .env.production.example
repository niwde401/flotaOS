# FlotaOS — Variables de entorno de PRODUCCIÓN
# Copiar como .env.production y completar todos los valores
# NUNCA commitear .env.production al repositorio (.gitignore ya lo protege)

# =============================================
# BASE DE DATOS (PostgreSQL)
# En EasyPanel el host es el nombre del servicio
# =============================================
DATABASE_URL=postgresql://flotaos:CAMBIAR_PASSWORD_DB@flotaos-postgres:5432/flotaos_db

# Necesarias solo si usas docker-compose.prod.yml directamente
POSTGRES_USER=flotaos
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_DB
POSTGRES_DB=flotaos_db

# =============================================
# AUTENTICACIÓN JWT
# Generar con PowerShell:
#   [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
# Ejecutar DOS veces — un valor diferente para cada secret
# =============================================
JWT_SECRET=GENERAR_MINIMO_48_CARACTERES
JWT_REFRESH_SECRET=GENERAR_MINIMO_48_CARACTERES_DIFERENTE

# =============================================
# REDIS
# =============================================
REDIS_URL=redis://flotaos-redis:6379
# Descomentar SOLO en desarrollo local sin Redis:
# REDIS_DISABLED=true

# =============================================
# MINIO (almacenamiento de fotos)
# El bucket se crea automáticamente al arrancar la API
# =============================================
MINIO_ENDPOINT=flotaos-minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=flotaos_minio
MINIO_SECRET_KEY=CAMBIAR_PASSWORD_MINIO
MINIO_BUCKET=flotaos-photos
# Descomentar SOLO en desarrollo local sin MinIO:
# MINIO_DISABLED=true

# =============================================
# APP
# =============================================
NODE_ENV=production
API_PORT=3001

# =============================================
# CORS — URL del frontend web
# =============================================
WEB_URL=https://app.TU_DOMINIO.com

# =============================================
# AI (Anthropic Claude)
# Obtener en: https://console.anthropic.com/
# =============================================
CLAUDE_API_KEY=sk-ant-XXXXXXXXXXXXXXXX

# =============================================
# NEXT.JS WEB
# API_URL: URL interna (server-side, dentro de EasyPanel)
# NEXT_PUBLIC_API_URL: URL pública (browser — opcional en esta arquitectura)
# =============================================
API_URL=http://flotaos-api:3001
NEXT_PUBLIC_API_URL=https://api.TU_DOMINIO.com
